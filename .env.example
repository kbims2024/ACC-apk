# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# MongoDB connection string
MONGO_URI="mongodb+srv://user:pass@cluster.mongodb.net/artisanchapchap"

# JWT Secret for authentication (Utilisé pour signer et sécuriser les connexions utilisateur)
JWT_SECRET="YOUR_JWT_SECRET"

# Google Maps Platform Key
GOOGLE_MAPS_PLATFORM_KEY="YOUR_GOOGLE_MAPS_KEY"

# Paystack Secret Key (Clé secrète de votre compte Paystack)
PAYSTACK_SECRET_KEY="sk_test_..."

# Stripe Configuration (Clés de votre compte Stripe)
STRIPE_SECRET_KEY="sk_test_..."
VITE_STRIPE_PUBLIC_KEY="pk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# Cloudinary (Pour le stockage tiers allégé des photos et vidéos)
VITE_CLOUDINARY_CLOUD_NAME=""
VITE_CLOUDINARY_UPLOAD_PRESET=""
